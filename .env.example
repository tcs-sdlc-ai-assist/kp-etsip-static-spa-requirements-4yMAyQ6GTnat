# Environment Variables Template for KP ETSIP SPA
# Copy this file to .env and fill in values as needed
#
# Note: Vite only exposes variables prefixed with VITE_ to the client
#       Access via import.meta.env.VITE_VARIABLE_NAME
#
# Core functionality requires no environment variables
# The following are examples for simulated features (if implemented):

# VITE_SIMULATED_API_DELAY=1000   # Mock API delay in ms
# VITE_SIMULATED_ERROR_RATE=0.1   # Mock error rate (0.0-1.0)
# VITE_FEATURE_FLAG_NEW_UI=false  # Example feature flag

# Do not commit actual .env files - they are gitignored
# See .gitignore for details